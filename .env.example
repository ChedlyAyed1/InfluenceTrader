APP_ENV=development
LOG_LEVEL=INFO

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TIMEOUT_SECONDS=20

X_DEFAULT_HANDLES=realDonaldTrump,elonmusk,warrenbuffett,jeromepowell
